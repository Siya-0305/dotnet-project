@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create Account - MOM System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-purple: #4e46e5;
            --card-header-bg: #f5f7ff;
            --primary-purple: #6366f1;
            --input-border: #e2e8f0;
            --text-muted: #718096;
        }

        body {
            background-color: var(--bg-purple);
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .reg-card {
            background: white;
            border-radius: 20px;
            width: 100%;
            max-width: 650px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .reg-header {
            background-color: var(--card-header-bg);
            padding: 40px 20px;
            text-align: center;
        }

        .brand-title {
            color: var(--primary-purple);
            font-weight: 700;
            font-size: 1.8rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .reg-body {
            padding: 40px;
        }

        /* Floating Label & Icon Style */
        .custom-input-group {
            position: relative;
            margin-bottom: 25px;
        }

        .input-icon {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--primary-purple);
            font-size: 1.1rem;
            z-index: 5;
        }

        .custom-control {
            background-color: #f8fafc;
            border: 1px solid var(--input-border);
            border-radius: 10px;
            padding: 15px 15px 15px 45px;
            width: 100%;
            transition: all 0.2s;
        }

            .custom-control:focus {
                outline: none;
                border-color: var(--primary-purple);
                background-color: #fff;
                box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.1);
            }

        /* Bordered Label effect for Role */
        .role-group {
            position: relative;
            border: 2px solid var(--primary-purple);
            border-radius: 10px;
        }

        .role-label {
            position: absolute;
            top: -12px;
            left: 20px;
            background: white;
            padding: 0 10px;
            color: var(--primary-purple);
            font-size: 0.85rem;
            font-weight: 600;
        }

        .help-text {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 5px;
            display: block;
        }

        /* Gradient Button */
        .btn-create {
            background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 100%);
            border: none;
            border-radius: 8px;
            padding: 12px;
            color: white;
            font-weight: 600;
            width: 100%;
            margin-top: 10px;
            transition: opacity 0.3s;
        }

            .btn-create:hover {
                opacity: 0.9;
                color: white;
            }

        .footer-link {
            text-align: center;
            margin-top: 25px;
            font-size: 0.9rem;
            color: var(--text-muted);
        }

            .footer-link a {
                color: var(--primary-purple);
                text-decoration: none;
                font-weight: 600;
            }
    </style>
</head>
<body>

    <div class="reg-card">
        <div class="reg-header">
            <div class="brand-title">
                <i class="bi bi-person-plus-fill"></i> Join MOM System
            </div>
            <h2 class="mt-3 fw-bold text-dark">Create Account</h2>
            <p class="text-muted small px-5">Join the meeting management system to organize and track meetings efficiently</p>
        </div>

        <div class="reg-body">
            <form asp-action="Register" method="post">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="custom-input-group">
                            <i class="bi bi-person input-icon"></i>
                            <input class="custom-control" placeholder="Username" />
                        </div>
                        <span class="help-text">3-50 characters required</span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="role-group">
                            <span class="role-label"><i class="bi bi-shield-check"></i> Role</span>
                            <select class="form-select border-0 shadow-none p-3 bg-transparent">
                                <option value="">Select Role</option>
                                <option value="Admin">Admin</option>
                                <option value="Member">Member</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="custom-input-group">
                            <i class="bi bi-key input-icon"></i>
                            <input type="password" class="custom-control" placeholder="Password" />
                        </div>
                        <span class="help-text">Minimum 6 characters</span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="custom-input-group">
                            <i class="bi bi-key input-icon"></i>
                            <input type="password" class="custom-control" placeholder="Confirm Password" />
                        </div>
                    </div>

                    <div class="col-12 mb-3">
                        <div class="custom-input-group mb-1">
                            <i class="bi bi-person-badge input-icon"></i>
                            <select class="custom-control form-select">
                                <option value="">Staff Member (Optional)</option>
                            </select>
                        </div>
                        <span class="help-text">Link to a staff member for better tracking</span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    Create Account
                </button>
           

            <div class="text-center mt-3">
                <p class="mb-0">
                    Already have an account?
                    <a asp-action="Login" class="text-primary fw-semibold">Sign in here</a>
                </p>
            </div>
            </form>
        </div>
    </div>

</body>
</html>
